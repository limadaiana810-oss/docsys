{
  "skill": {
    "name": "docsys",
    "version": "3.0.0",
    "trigger": "小凯"
  },
  "paths": {
    "media":    "{HOME}/.openclaw/media/",
    "inbound":  "{HOME}/.openclaw/media/inbound/",
    "outbound": "{HOME}/.openclaw/media/outbound/",
    "workspace":"{HOME}/.openclaw/workspace/"
  },
  "db": {
    "home": "{HOME}/.openclaw/media/home/hub/meta.db",
    "work": "{HOME}/.openclaw/media/work/hub/meta.db"
  },
  "api": {
    "config_file": "{HOME}/.openclaw/config/image_gen.json"
  },
  "spaces": {
    "home": {
      "name": "家庭空间",
      "root": "{HOME}/.openclaw/media/home/",
      "sub_spaces": {
        "wrong_questions":   "learning/wrong_questions/",
        "classic_questions": "learning/classic_questions/",
        "quick_review":      "learning/quick_review/",
        "documents":         "documents/"
      }
    },
    "work": {
      "name": "办公空间",
      "root": "{HOME}/.openclaw/media/work/",
      "sub_spaces": {
        "reimbursement": "reimbursement/",
        "documents":     "documents/"
      }
    }
  },
  "multimodal_model": "qwen/qwen2.5-vl-72b-instruct",
  "image_gen_model":  "google/gemini-3.1-flash-image-preview"
}
